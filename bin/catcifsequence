#!/usr/bin/env python3
"""catcifsequence — extract per-chain sequences from a .catcif file.

Can be invoked three ways:
  1. pip install catcif-tools  →  catcifsequence (entry point wrapper in venv bin/)
  2. export PATH=".../catcif_tools/bin:$PATH"  →  catcifsequence
  3. /full/path/to/catcif_tools/bin/catcifsequence
"""
import sys
import os

try:
    from catcif_tools.catcifsequence import main
except ImportError:
    _project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    sys.path.insert(0, _project_root)
    from catcif_tools.catcifsequence import main

main()
