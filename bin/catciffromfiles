#!/usr/bin/env python3
"""catciffromfiles — build a .catcif file from individual structure files.

Can be invoked three ways:
  1. pip install catcif-tools  →  catciffromfiles (entry point wrapper in venv bin/)
  2. export PATH=".../catcif_tools/bin:$PATH"  →  catciffromfiles
  3. /full/path/to/catcif_tools/bin/catciffromfiles
"""
import sys
import os

try:
    from catcif_tools.catciffromfiles import main
except ImportError:
    _project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    sys.path.insert(0, _project_root)
    from catcif_tools.catciffromfiles import main

main()
