#!/usr/bin/env python3
"""catcifscorefile — extract scores from a .catcif file to a score file.

Can be invoked three ways:
  1. pip install catcif-tools  →  catcifscorefile (entry point wrapper in venv bin/)
  2. export PATH=".../catcif_tools/bin:$PATH"  →  catcifscorefile
  3. /full/path/to/catcif_tools/bin/catcifscorefile
"""
import sys
import os

try:
    from catcif_tools.catcifscorefile import main
except ImportError:
    _project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    sys.path.insert(0, _project_root)
    from catcif_tools.catcifscorefile import main

main()
