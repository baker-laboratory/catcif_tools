#!/usr/bin/env python3
"""catcifextract — write each structure from a .catcif file to its own .cif file.

Can be invoked three ways:
  1. pip install catcif-tools  →  catcifextract (entry point wrapper in venv bin/)
  2. export PATH=".../catcif_tools/bin:$PATH"  →  catcifextract
  3. /full/path/to/catcif_tools/bin/catcifextract
"""
import sys
import os

try:
    from catcif_tools.catcifextract import main
except ImportError:
    _project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    sys.path.insert(0, _project_root)
    from catcif_tools.catcifextract import main

main()
