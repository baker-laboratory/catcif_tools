#!/usr/bin/env python3
"""catcifsplit — split a .catcif file into multiple smaller files.

Can be invoked three ways:
  1. pip install catcif-tools  →  catcifsplit (entry point wrapper in venv bin/)
  2. export PATH=".../catcif_tools/bin:$PATH"  →  catcifsplit
  3. /full/path/to/catcif_tools/bin/catcifsplit
"""
import sys
import os

try:
    from catcif_tools.catcifsplit import main
except ImportError:
    _project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    sys.path.insert(0, _project_root)
    from catcif_tools.catcifsplit import main

main()
